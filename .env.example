# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN_MAIN=

# ── Security Allowlists ───────────────────────────────────────────────────────
# Comma-separated Telegram user IDs (get yours via /whoami after Phase 1)
TELEGRAM_ALLOWED_USER_IDS=
# Comma-separated group/channel IDs (optional — DMs only if left empty)
TELEGRAM_ALLOWED_CHAT_IDS=

# ── Memory ────────────────────────────────────────────────────────────────────
# Embedding provider: local | openai | none
# local = sentence-transformers/all-MiniLM-L6-v2 (80MB, CPU, no API key)
# openai = text-embedding-3-small (requires OPENAI_API_KEY)
# none  = BM25 keyword search only
MEMORY_EMBEDDING_PROVIDER=local
MEMORY_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Opt-in: index raw session JSONL logs for memory_search
MEMORY_SESSION_INDEXING=false
MEMORY_SESSION_DELTA_BYTES=100000
MEMORY_SESSION_DELTA_MESSAGES=50

# Dreaming sweep (nightly consolidation of daily notes → MEMORY.md candidates)
DREAMING_ENABLED=false
DREAMING_LOOKBACK_DAYS=30
DREAMING_PROMOTION_THRESHOLD=0.6

# ── Obsidian ──────────────────────────────────────────────────────────────────
OBSIDIAN_VAULT_PATH=

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8000

# ── Connectors / MCP tool access ──────────────────────────────────────────────
# Controls which tools Main is allowed to call.
# "*"       — allow everything (all MCP servers, no restriction) — recommended
# ""        — base tools only (Bash, Read, Write, Edit, WebSearch, memory_*)
# "tool1,tool2" — base tools plus these specific MCP tool names
MAIN_EXTRA_TOOLS=*

# Credentials for MCP servers (add as needed after running claude mcp add <name>)
# GitHub — needed by @modelcontextprotocol/server-github
GITHUB_PERSONAL_ACCESS_TOKEN=
# HubSpot — needed by @hubspot/mcp
HUBSPOT_ACCESS_TOKEN=
# Slack — needed by @modelcontextprotocol/server-slack
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=
# Linear — needed by @linear/mcp
LINEAR_API_KEY=

# ── Voice transcription ───────────────────────────────────────────────────────
# openai = use OpenAI Whisper API (fast, requires OPENAI_API_KEY)
# local  = use faster-whisper on CPU (no API key, ~500 MB model download)
# none   = voice messages unsupported (default)
WHISPER_PROVIDER=none
OPENAI_API_KEY=

# ── Discord channel ───────────────────────────────────────────────────────────
# Leave blank to disable Discord integration
DISCORD_BOT_TOKEN=
# Comma-separated Discord user IDs who can message the bot (empty = allow all)
DISCORD_ALLOWED_USER_IDS=
# Comma-separated Discord server/guild IDs (empty = allow all guilds)
DISCORD_ALLOWED_GUILD_IDS=

# ── NOTE: ANTHROPIC_API_KEY intentionally omitted ─────────────────────────────
# Auth rides on ~/.claude/.credentials.json (Claude CLI OAuth).
# Setting ANTHROPIC_API_KEY switches billing from subscription to metered API.
# Do NOT set it.
