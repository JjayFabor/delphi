# agents/coder/

# Local Claude Code settings (personal overrides)
.claude/settings.local.json

# Personal cron job config (copy from cron-config.example.json and fill in your credentials)
agents/main/cron-config.json

# Personal soul files
agents/shared/USER_PROFILE.md
agents/shared/BUSINESS_CONTEXT.md
agents/shared/HOUSE_RULES.md

# macOS
.DS_Store

